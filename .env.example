# ========================================
# 环境变量配置模板
# ========================================
# 说明：
# 1. 复制此文件为 .env.local 并填入真实的密钥
# 2. .env.local 已在 .gitignore 中，不会被提交到 Git
# 3. 永远不要将包含真实密钥的 .env.local 提交到版本控制系统
# 4. 请妥善保管您的 API Key，不要泄露给他人
# ========================================

# ========================================
# GPT-5 文本分析配置（OpenAI 兼容 API）
# ========================================
# 说明：用于文本提取、分析、分镜生成等（使用 mobaohee.xyz 兼容接口）
# 获取方式：https://mobaohee.xyz
OPENAI_API_KEY=your_openai_api_key_here

# ========================================
# Seedance 2.0 视频生成配置（xszy.top 代理）
# ========================================
# 说明：用于 Seedance 2.0 视频生成和视频编辑功能
# 使用 https://www.xszy.top 作为 API 代理（OpenAI 兼容接口）
XSZY_API_KEY=your-xszy-api-key-here

# ========================================
# manfei 视频生成配置
# ========================================
# 固定使用 moon-manfei-new + 720p
MANFEI_API_KEY=your-manfei-token-here
MANFEI_BASE_URL=http://115.191.42.226:8001

# ========================================
# manfei 本地图片公网中转（火山引擎 TOS）
# ========================================
TOS_ENDPOINT=https://tos-cn-beijing.volces.com
ASSET_STORAGE_REGION=cn-beijing
TOS_BUCKET_NAME=ark-auto-2119577522-cn-beijing-default
TOS_ACCESS_POINT_ALIAS=your-access-point-alias
TOS_ACCESS_KEY_ID=your-access-key-id
TOS_SECRET_ACCESS_KEY=your-secret-access-key

# ========================================
# RunningHub 图片生成配置
# ========================================
# 说明：用于 RunningHub Namo Banana Pro 图片生成
# 获取方式：访问 https://www.runninghub.cn 注册并获取 API Key
RUNNINGHUB_API_KEY=your-runninghub-api-key-here

# ========================================
# 对象存储配置（S3）
# ========================================
# 说明：用于存储生成的图片、视频等文件
# 这些配置通常由系统自动设置，无需手动配置
COZE_BUCKET_ENDPOINT_URL=https://your-bucket-endpoint-url
COZE_BUCKET_NAME=your-bucket-name

# ========================================
# 可选配置
# ========================================
# 说明：以下配置为可选，根据需要设置

# 日志级别（可选）
# 可选值：debug, info, warn, error
LOG_LEVEL=info

# API 超时时间（可选，单位：毫秒）
API_TIMEOUT=30000

# ========================================
# 安全提示
# ========================================
# ⚠️ 重要安全事项：
# 1. 绝不要将包含真实密钥的文件提交到 Git
# 2. 定期轮换您的 API Key
# 3. 为不同的环境（开发、测试、生产）使用不同的 API Key
# 4. 如果怀疑密钥泄露，立即撤销并生成新的密钥
# 5. 不要在代码中硬编码任何密钥或凭证
